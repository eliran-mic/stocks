# Required
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional - App settings
# DATA_DIR=./data
# STOP_LOSS_PCT=10
# TAKE_PROFIT_PCT=20
# ALERT_INTERVAL_MINUTES=30
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Cloud Run (set automatically by deploy scripts)
# WEBHOOK_URL=https://stocks-bot-xxxxx.run.app
# K_SERVICE=stocks-bot
# PORT=8080

# GCP setup (used by setup.sh / deploy.sh)
# GCP_REGION=us-central1
